/*
 * Configuração principal do pipeline Milena-MD (DN773-GORE12T)
 * Adaptado de MD-gromacs/nextflow.config — mesma estrutura de params/profiles,
 * com MM-GBSA (stability_filter → clustering → mmgbsa_robust → mmgbsa_interpret)
 * encadeado no fluxo padrão do main.nf.
 */

params {
    // --- Entrada/Saída ---
    input          = null
    outdir         = "${System.getenv('HOME')}/gromacs/results"

    // --- Parâmetros físicos ---
    pH             = 8.2
    time_ns        = 100
    forcefield     = 'amber99sb-ildn'
    water          = 'tip3p'
    nacl_conc      = 0.10   // midgut inseto é hipotônico; literatura usa 0.10-0.15 M
    cation         = 'K'    // hemolínfa de insetos é dominada por K+ (vs NA em mamíferos)
    temperature    = 300
    box_dist       = 2.0   // 2.0 nm margem segura para complexos prot-peptídeo (evita PBC)
    window_ns      = 5.0   // janela da média móvel nos gráficos (ns)
    box_type       = 'cubic'   // caixa cúbica: geometria simples, sem artefatos de dodecaedro

    // --- GROMACS ---
    gmx_cmd        = 'gmx_mpi'      // build conda-forge com CUDA usa gmx_mpi
    mpi_cmd        = 'mpirun -np 1' // 1 rank MPI + ntomp threads OpenMP
    use_gpu        = true
    gpu_id         = 0
    ntomp          = 8
    maxwarn        = 2

    // --- Resíduos de interesse para distâncias (fallback global) ---
    // Preferir definir por sistema no samplesheet (colunas triad_1..4)
    // DN773: His69, Asp116, Ser213, Gly207 (S1) — ver assets/samplesheet_dn773_gore12t.csv
    triad_1        = 0
    triad_2        = 0
    triad_3        = 0
    triad_4        = 0   // bolsão S1

    // --- Pipeline MMGBSA robusto ---
    // Filtragem de estabilidade (detecção do plateau do RMSD)
    stability_min_frac      = 0.3   // descarta no mínimo os primeiros 30%
    stability_window_ns     = 5.0   // janela deslizante para detecção de plateau
    stability_threshold     = 0.15  // fração do SD global abaixo da qual = estável

    // Clustering (GROMOS sobre o grupo Ligante)
    cluster_cutoff              = 0.2  // cutoff RMSD em nm
    mmgbsa_n_clusters           = 3    // clusters mais populosos a usar
    mmgbsa_frames_per_cluster   = 50   // frames por cluster → ~150 frames total
}

// Carrega configurações por perfil
profiles {
    local   { includeConfig 'conf/local.config'  }
    slurm   { includeConfig 'conf/slurm.config'  }
    conda   {
        conda.enabled          = true
        conda.useMamba         = true
        process.conda          = "${System.getenv('HOME')}/miniforge3/envs/md-gromacs"

        // PLOT e MMGBSA_INTERPRET importam matplotlib/numpy. O env
        // md-gromacs (118+ pacotes: GROMACS, AmberTools, MDAnalysis etc.)
        // teve uma instalação de matplotlib corrompida (2026-07-02:
        // matplotlib.cbook faltando _is_pandas_dataframe mesmo após
        // reinstall completo numpy+matplotlib) -- não era cache obsoleto,
        // o pacote instalado estava mesmo incompleto. Env dedicado e leve
        // (`mamba create -n plot-env python=3.11 numpy matplotlib
        // -c conda-forge`) resolveu. Isola os dois processos de plot do
        // resto do pipeline (que não precisa de matplotlib) para não
        // arriscar quebrar de novo.
        withName: 'PLOT' {
            conda = "${System.getenv('HOME')}/miniforge3/envs/plot-env"
        }
        withName: 'MMGBSA_INTERPRET' {
            conda = "${System.getenv('HOME')}/miniforge3/envs/plot-env"
        }
    }
}

// Configuração base de recursos
includeConfig 'conf/base.config'

// Relatório de execução
// overwrite = true evita FileAlreadyExistsException ao rodar com -resume
// depois de uma tentativa anterior já ter gerado esses arquivos.
report {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/pipeline_report.html"
}
timeline {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/timeline.html"
}
dag {
    enabled   = true
    overwrite = true
    file      = "${params.outdir}/dag.svg"
}

manifest {
    name            = 'Milena-MD'
    description     = 'Pipeline Dinâmica Molecular GROMACS — DN773-GORE12T (com MM-GBSA automatizado)'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
}
